# Docker Compose development (backend runs inside container)
NODE_ENV=development
PORT=3000

CLIENT_URL=http://localhost:5173

# Mongo:
# If you DON'T run Mongo in this compose file, point to an external Mongo reachable from the backend container.
# Common options:
# - Another compose project network alias
# - A managed MongoDB URL
# - host.docker.internal (Windows/Mac) for a Mongo running on your host
#
# Example (Mongo on host machine):
# MONGO_URL=mongodb://host.docker.internal:27017
MONGO_URL=mongodb://host.docker.internal:27017

# Redis service in this compose file
REDISH_URL=redis://redis:6379

# MinIO service in this compose file
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS=minioadmin
MINIO_SECRET=minioadmin
STORAGE_BUCKET=devbucket
FILE_BASE_URL=http://minio:9000/devbucket

JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
