# Local development (runs backend on your machine)
NODE_ENV=development
PORT=3000

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Mongo (NOTE: code appends /E-commerce automatically)
MONGO_URL=mongodb://127.0.0.1:27017

# Redis (host machine)
REDISH_URL=redis://localhost:6379

# S3-compatible storage (MinIO on host)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS=minioadmin
MINIO_SECRET=minioadmin
STORAGE_BUCKET=devbucket
FILE_BASE_URL=http://localhost:9000/devbucket

# JWT
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
